{
  "validator": "tools/pipeline/ui_toolkit_graphics/validate_package.py",
  "cases": [
    {
      "name": "valid-minimal-package",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/valid/minimal-package",
      "expectValid": true,
      "expectedOutputContains": "Validation passed"
    },
    {
      "name": "valid-dot-path-equivalence",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/valid/dot-path-equivalence",
      "expectValid": true,
      "expectedOutputContains": "Validation passed"
    },
    {
      "name": "invalid-missing-visual-tree-file",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/invalid/missing-visual-tree-file",
      "expectValid": false,
      "expectedOutputContains": "Asset file listed in common.assets is missing"
    },
    {
      "name": "invalid-wrong-family",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/invalid/wrong-family",
      "expectValid": false,
      "expectedOutputContains": "pipeline.family must be 'ui-toolkit-graphics'"
    },
    {
      "name": "invalid-source-missing-fields",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/invalid/source-missing-fields",
      "expectValid": false,
      "expectedOutputContains": "common.source.repository must be a non-empty string."
    },
    {
      "name": "invalid-tilde-in-path",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/invalid/tilde-in-path",
      "expectValid": false,
      "expectedOutputContains": "must be a safe relative path"
    },
    {
      "name": "invalid-symlink-escape",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/invalid/symlink-escape/package",
      "expectValid": false,
      "expectedOutputContains": "resolves outside package root"
    },
    {
      "name": "invalid-manifest-name-path-traversal",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/valid/minimal-package",
      "manifestName": "../manifest.json",
      "expectValid": false,
      "expectedOutputContains": "manifest-name must be a safe relative path"
    },
    {
      "name": "invalid-manifest-name-empty",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/valid/minimal-package",
      "manifestName": "",
      "expectValid": false,
      "expectedOutputContains": "manifest-name must be a non-empty string."
    },
    {
      "name": "invalid-manifest-name-windows-separator-traversal",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/valid/minimal-package",
      "manifestName": "..\\\\manifest.json",
      "expectValid": false,
      "expectedOutputContains": "manifest-name must be a safe relative path"
    },
    {
      "name": "invalid-display-name-too-long",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/invalid/display-name-too-long",
      "expectValid": false,
      "expectedOutputContains": "common.displayName must be at most 200 characters."
    },
    {
      "name": "invalid-unexpected-common-field",
      "packageRoot": "fixtures/validation/ui-toolkit-graphics-package/invalid/unexpected-common-field",
      "expectValid": false,
      "expectedOutputContains": "common contains unsupported field: unsupportedField."
    }
  ]
}
